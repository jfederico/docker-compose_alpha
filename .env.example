COMPOSE_PROJECT_NAME=docker-compose-alpha

# Public bind addresses for the alpha LXC. Leave as 0.0.0.0 unless the LXC
# has multiple interfaces and Caddy should listen only on one of them.
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0

# LetsEncrypt account and Cloudflare DNS-01 automation.
LETSENCRYPT_EMAIL=admin@example.com
CLOUDFLARE_DNS_API_TOKEN=replace-with-cloudflare-dns-edit-token

# Temporary bridge to the current Seri deployment.
# This should be an internal HTTP listener on Seri, not the old public 80/443
# proxy. Example: http://172.16.0.105:8080
LEGACY_SERI_HTTP=http://seri-lan-ip:8080
